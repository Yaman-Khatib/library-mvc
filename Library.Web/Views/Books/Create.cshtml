@model Library.Web.Models.Books.BookFormViewModel
@{
    ViewData["Title"] = "Add New Book";
}

<div class="bg-white">
    <div class="bg-[#f7f9fb] border-b border-[#e0e3e5] mb-8">
        <div class="max-w-7xl mx-auto px-6 py-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <p class="text-xs font-bold text-[#75777d] uppercase tracking-widest mb-2">Catalog</p>
                    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#091426] mb-2">Add New Entry</h1>
                    <p class="text-[#45474c] max-w-2xl">Create a new book record in the library collection.</p>
                </div>
                <div class="flex gap-3">
                    <a asp-action="Index" class="px-4 py-2 bg-white border border-[#c5c6cd] rounded-md text-sm font-semibold text-[#091426] hover:border-[#904d00] hover:text-[#904d00] transition">Back</a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pb-12">
        <div class="max-w-3xl">
            <div class="bg-white border border-[#e0e3e5] rounded-lg p-6">
                <form asp-action="Create" method="post" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="mb-2 p-4 bg-[#ffdad6] text-[#93000a] rounded-md text-sm"></div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Title" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                            <input asp-for="Title" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition" />
                            <span asp-validation-for="Title" class="text-[#93000a] text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="Author" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                            <input asp-for="Author" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition" />
                            <span asp-validation-for="Author" class="text-[#93000a] text-xs"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Isbn" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                            <input asp-for="Isbn" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition" />
                            <span asp-validation-for="Isbn" class="text-[#93000a] text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="TotalCopies" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                            <input asp-for="TotalCopies" type="number" min="0" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition" />
                            <span asp-validation-for="TotalCopies" class="text-[#93000a] text-xs"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="LanguageId" class="block text-sm font-semibold text-[#191c1e] mb-2">Language</label>
                            <select asp-for="LanguageId" asp-items="ViewBag.Languages" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition">
                                <option value="">Select language...</option>
                            </select>
                            <span asp-validation-for="LanguageId" class="text-[#93000a] text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="GenreId" class="block text-sm font-semibold text-[#191c1e] mb-2">Genre</label>
                            <select asp-for="GenreId" asp-items="ViewBag.Genres" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition">
                                <option value="">Select genre...</option>
                            </select>
                            <span asp-validation-for="GenreId" class="text-[#93000a] text-xs"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                        <textarea asp-for="Description" rows="5" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition"></textarea>
                        <span asp-validation-for="Description" class="text-[#93000a] text-xs"></span>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="px-6 py-3 bg-gradient-to-br from-[#091426] to-[#1e293b] text-white rounded-md text-sm font-semibold hover:opacity-90 transition">
                            Create Book
                        </button>
                        <a asp-action="Index" class="px-6 py-3 bg-white border border-[#c5c6cd] rounded-md text-sm font-semibold text-[#091426] hover:border-[#904d00] hover:text-[#904d00] transition">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

