@{
    ViewData["Title"] = "Access denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied - Library MVC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Manrope', sans-serif; }
    </style>
</head>
<body class="bg-white">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="w-full max-w-md text-center">
            <h1 class="text-3xl font-bold text-[#091426] mb-2">Access denied</h1>
            <p class="text-[#45474c] mb-6">You do not have access to this resource.</p>

            <a asp-controller="Home" asp-action="Index" class="inline-block px-6 py-3 bg-gradient-to-br from-[#091426] to-[#1e293b] text-white rounded-md font-semibold hover:opacity-90 transition">
                Go Home
            </a>
        </div>
    </div>
</body>
</html>
