@model Library.Web.Models.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Library MVC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Manrope', sans-serif; }
    </style>
</head>
<body class="bg-white">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="w-full max-w-md">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-[#091426] mb-2">Library MVC</h1>
                <p class="text-[#45474c]">Create your account</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-[#ffdad6] text-[#93000a] rounded-md text-sm"></div>
            }

            <form method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="FirstName" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                        <input asp-for="FirstName" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" placeholder="John" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-[#93000a] text-xs"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                        <input asp-for="LastName" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" placeholder="Doe" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-[#93000a] text-xs"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="DateOfBirth" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                    <input asp-for="DateOfBirth" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" />
                    <span asp-validation-for="DateOfBirth" class="text-[#93000a] text-xs"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                    <input asp-for="Email" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-[#93000a] text-xs"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                    <input asp-for="Password" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-[#93000a] text-xs"></span>
                    <p class="text-xs text-[#45474c] mt-1">At least 8 characters</p>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-[#191c1e] mb-2"></label>
                    <input asp-for="ConfirmPassword" class="w-full px-4 py-2 bg-[#e0e3e5] rounded-md border-b-2 border-[#75777d] border-opacity-30 focus:border-[#904d00] focus:outline-none transition" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-[#93000a] text-xs"></span>
                </div>

                <button type="submit" class="w-full px-6 py-3 bg-gradient-to-br from-[#091426] to-[#1e293b] text-white rounded-md font-semibold hover:opacity-90 transition">Create Account</button>
            </form>

            <p class="text-center text-[#45474c] mt-6">
                Already have an account?
                <a href="/Auth/Login" class="text-[#904d00] font-semibold hover:underline">Sign in</a>
            </p>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
