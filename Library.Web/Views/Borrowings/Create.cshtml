@model Library.Web.Models.Borrowings.BorrowingCreateViewModel
@{
    ViewData["Title"] = "Borrow a Book";
}

<div class="bg-white">
    <div class="bg-[#f7f9fb] border-b border-[#e0e3e5] mb-8">
        <div class="max-w-7xl mx-auto px-6 py-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <p class="text-xs font-bold text-[#75777d] uppercase tracking-widest mb-2">Borrowing</p>
                    <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#091426] mb-2">Borrow a Book</h1>
                    <p class="text-[#45474c] max-w-2xl">Confirm the book and set a due date.</p>
                </div>
                <div class="flex gap-3">
                    <a asp-action="Index" class="px-4 py-2 bg-white border border-[#c5c6cd] rounded-md text-sm font-semibold text-[#091426] hover:border-[#904d00] hover:text-[#904d00] transition">Back</a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pb-12">
        <div class="max-w-3xl">
            <div class="bg-white border border-[#e0e3e5] rounded-lg p-6">
                <form asp-action="Create" method="post" asp-antiforgery="true" class="space-y-5">

                    <div asp-validation-summary="ModelOnly" class="mb-2 p-4 bg-[#ffdad6] text-[#93000a] rounded-md text-sm"></div>

                    <div>
                        <label class="block text-sm font-semibold text-[#191c1e] mb-2">Book</label>
                        <input type="hidden" asp-for="BookId" />
                        <div class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd]">
                            <div class="flex items-center justify-between gap-4">
                                <p class="text-sm font-semibold text-[#091426] truncate">
                                    @(string.IsNullOrWhiteSpace(Model.BookTitle) ? "Selected book" : Model.BookTitle)
                                </p>
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.BookId" class="text-xs font-semibold text-[#904d00] hover:underline whitespace-nowrap">
                                    View details
                                </a>
                            </div>
                        </div>
                        <span asp-validation-for="BookId" class="text-[#93000a] text-xs"></span>
                    </div>

                    <div>
                        <label asp-for="DueDateUtc" class="block text-sm font-semibold text-[#191c1e] mb-2">Due date</label>
                        <input asp-for="DueDateUtc" type="date" class="w-full px-4 py-2 bg-[#f2f4f6] rounded-md border border-[#c5c6cd] focus:border-[#904d00] focus:outline-none transition" />
                        <span asp-validation-for="DueDateUtc" class="text-[#93000a] text-xs"></span>
                        <p class="text-xs text-[#45474c] mt-1">Due dates are stored in UTC.</p>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <button type="submit" class="px-6 py-3 bg-gradient-to-br from-[#091426] to-[#1e293b] text-white rounded-md text-sm font-semibold hover:opacity-90 transition">
                            Borrow
                        </button>
                        <a asp-action="Index" class="px-6 py-3 bg-white border border-[#c5c6cd] rounded-md text-sm font-semibold text-[#091426] hover:border-[#904d00] hover:text-[#904d00] transition">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
